{
    "$schema": "/etc/xdg/swaync/configSchema.json",
    "positionX" : "left",
    "positionY" : "bottom",

    "cssPriority" : "user",

    "control-center-width": 450,
    "control-center-height": 750,
    "control-center-margin-top": 0,
    "control-center-margin-bottom": 3,
    "control-center-margin-right": 0,
    "control-center-margin-left": 3,

    "notification-window-width": 300,
    "notification-icon-size": 48,
    "notification-body-image-height": 160,
    "notification-body-image-width": 250,

    "timeout": 6,
    "timeout-low": 4,
    "timeout-critical": 0,

    "script-fail-notify": true,
    "keyboard-shortcuts": true,
    "hide-on-action": true,
    "hide-on-clear": false,
    "fit-to-screen": false,

    "text-empty": "No Notifications",
    "image-visibility": "when-available",
    "transition-time": 200,

    "notification-visibility": {
        "example-name": {
            "state": "muted",
            "urgency": "Low",
            "app-name": "Spotify"
        }
    },

    "widgets": [
        "buttons-grid",
        "mpris",
        "volume",
        "backlight",
        "dnd",
        "title",
        "notifications"
    ],
    "widget-config": {
        "title": {
            "text": "Notifications",
            "clear-all-button": true,
            "button-text": "󰆴"
        },

        "mpris": {
            "image-size": 50,
            "image-radius": 8
        },

        "dnd": {
            "text": "Do Not Disturb"
        },

        "volume": {
            "label": " 󰕾 ",
            "expand-button-label": " ",
            "collapse-button-label": " ",
            "show-per-app": true,
            "show-per-app-icon": true,
            "show-per-app-label": false
        },

        "backlight": {
            "label": " 󰃟 "
        },

        "buttons-grid": {
            "actions": [
                {
                    "label": "󰐥",
                    "command": "systemctl poweroff"
                },
                {
                    "label": "󰜉",
                    "command": "systemctl reboot"
                },
                {
                    "label": "",
                    "command": "dolphin"
                },
                {
                    "label": "",
                    "command": "flatpak run com.saivert.pwvucontrol"
                }
            ]
        }
    }
}