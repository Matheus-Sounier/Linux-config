                                "σΑÉû",
                                "σΑÉü",
                                "σΑÉ†"
            ],
        "on-scroll-up": "brightnessctl set +5%",
        "on-scroll-down": "brightnessctl set 5%-"
    },

    "battery": {
        "states": {
            "good": 95,
            "warning": 30,
            "critical": 20
        },
        "format": "{icon} {capacity}%",
        "rotate": 0,
        "format-charging": "ο΅Π {capacity}%",
        "format-plugged": "ο΅Π {capacity}%",
        "format-alt": "{time} {icon}",
        "format-full": "σΑ²Ö",
        "format-icons": [
                "σΑ²é",
                "σΑ¹Κ",
                "σΑ¹Μ",
                "σΑ¹Φ",
                "σΑ¹Ϋ",
                "σΑ¹Ψ",
                "σΑ¹Ω",
                "σΑ²Ä",
                "σΑ²¹",
                "σΑ²²",
                "σΑ¹Ι"
        ],
        "tooltip-format-discharging": "{power:>1.0f}WβÜ™ {capacity}% | {time}",
        "tooltip-format-charging": "{power:>1.0f}WβÜë {capacity}% | {time}"
    },

    "pulseaudio#microphone": {
