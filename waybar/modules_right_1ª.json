        "on-scroll-up": "mic-level increase",
        "on-scroll-down": "mic-level decrease",
        "scroll-step": 5,
        "tooltip": false,
        "tooltip-format": "Mic Level: {volume}%"
    },

    "pulseaudio": {
        "format": "{icon}  {volume}%",
        "format-bluetooth": "{icon}  {volume}%",
