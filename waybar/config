{
  "layer": "top",
  "spacing": 0,
  "height": 0,
  "margin-bottom": 2,
  "margin-top": 2,
  "position": "top",
  "margin-right": 500,
  "margin-left": 500,
  "modules-left": [
    "sway/workspaces"
  ],
  "modules-center": [
    "custom/applauncher"
  ],
  "modules-right": [
    "network",
    "battery",
    "pulseaudio",
    "mpris",
    "tray",
    "clock"
  ],
  "sway/workspaces": {
    "disable-scroll": true,
    "all-outputs": false,
    "tooltip": false
  },
  "custom/applauncher": {
    "format": "⚙",
    "on-click": "pgrep wofi >/dev/null 2>&1 && killall wofi || wofi --show drun --location=top -y 15",
    "tooltip": false
  },
  "tray": {
    "spacing": 10,
    "tooltip": false
  },
  "clock": {
    "format": "󰅐  {:%H:%M}",
    "tooltip": false
  },
  "network": {
    "format-wifi": "   {bandwidthDownBits}",
    "format-ethernet": "   {bandwidthDownBits}",
    "format-disconnected": "󰤮   No Network",
    "interval": 2,
    "tooltip": false
  },

  "pulseaudio": {
  "scroll-step": 5,
  "max-volume": 150,
  "format": "{icon} {volume}%",
  "format-bluetooth": "{icon} {volume}%",
  "format-icons": {
    "default": ["🔈", "🔉", "🔊"]
  },
  "format-muted": "🔇",
  "on-click": "pavucontrol",
  "tooltip": false
  },
  
  "mpris": {
  "format": "{player_icon} {title}",
  "format-paused": "{player_icon} <i>{title}</i>",
  "player-icons": {
    "default": "♪",
    "spotify": "♫",
    "mpv": "▶",
    "vlc": "▶",
    "chrome": "🌐"
  },
  "ignored-players": ["playerctld"],
  "max-length": 30,
  "tooltip-format": "{artist} - {album}\n{title}",
  "on-click": "playerctl play-pause",
  "on-scroll-up": "playerctl next",
  "on-scroll-down": "playerctl previous"
  },

  "battery": {
    "format": "{icon} {capacity}%",
    "format-charging": "󰂄 {capacity}%",
    "format-plugged": "󰂄 {capacity}%",
    "format-alt": "{icon} {time}",
    "format-full": "󱈑 {capacity}%",
    "format-icons": [
      "󱊡",
      "󱊢",
      "󱊣"
    ]
  }
}